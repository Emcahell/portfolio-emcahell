---
import Card from "../components/ui/Card.astro";
import CardProject from "../components/ui/CardProject.astro";
import ImgEnrolmentStatistics from "../assets/estadistica-matricula.webp";
import ImgStatesVzla from "../assets/estados-vzla-webpage.webp";
import ImgOptimizeImg from "../assets/optimizeimg.webp";
import ImgDistrictPanem from "../assets/distritos-panem.webp";
import ImgTop from "../assets/top-webpage.webp";
import ImgKefren from "../assets/web-kefren-art.webp";
import ImgOneStarlink from "../assets/one-starlink.webp";
import ImgChatIAEmma from "../assets/chat-AI-emma.png";
import { translations } from "../i18n/translations";

const projects = [
  {
    image: ImgEnrolmentStatistics,
    alt: "Proyecto Estadistica de Matrícula",
    href: "https://estadisticadematricula.vercel.app/",
    title: "Estadistica de matricula",
    descriptionKey: "projectStatistics",
    badges: ["HTML", "CSS", "JavaScript"],
  },
  {
    image: ImgStatesVzla,
    alt: "Proyecto Estados de Venezuela",
    href: "https://estados-vzla.vercel.app/",
    title: "Estados de Venezuela",
    descriptionKey: "projectStatesVzla",
    badges: ["React", "Tailwind"],
  },
  {
    image: ImgOptimizeImg,
    alt: "Proyecto Optimize Image",
    href: "https://optimizeimg.vercel.app/",
    title: "Optimize Image",
    descriptionKey:
      "projectOptimizeImage",
    badges: ["Next", "TypeScript", "Tailwind"],
  },
  {
    image: ImgChatIAEmma,
    alt: "Proyecto chatbot ia",
    href: "https://chat-ia-emma.vercel.app/",
    title: "Chat IA Emma",
    descriptionKey:
      "projectChatIaEmma",
    badges: ["Next", "Tailwind"],
  },
  {
    image: ImgOneStarlink,
    alt: "Landing page One Starlink",
    href: "https://one-starlink.vercel.app/",
    title: "One Starlink",
    descriptionKey: "projectOneStarlink",
    badges: ["Next", "Tailwind", "Motion"],
  },
  {
    image: ImgDistrictPanem,
    alt: "Proyecto Distritos de Panem",
    href: "https://districts-of-panem.vercel.app/",
    title: "Distritos de Panem",
    descriptionKey: "projectDistrictsPanem",
    badges: ["Astro", "Preact", "Tailwind"],
  },
  {
    image: ImgKefren,
    alt: "Proyecto Kefren Art portfolio",
    href: "https://kefren-art.vercel.app",
    title: "Portafolio Kefren Art",
    descriptionKey: "projectKefren",
    badges: ["Astro", "React", "Tailwind"],
  },
  {
    image: ImgTop,
    alt: "Proyecto Twenty One Pilots",
    href: "https://welcome-to-the-world-of-twenty-one-pilots.vercel.app/",
    title: "Twenty One Pilots",
    descriptionKey: "projectTop",
    badges: ["HTML", "CSS", "JavaScript"],
  },
];
---

<Card>
  <main class="p-4 sm:p-8 md:h-[calc(100vh-4rem)] md:overflow-y-auto">
    <div class="mb-8">
      <p
        class="text-lg text-emerald-950 dark:text-emerald-100 font-family-nunito tracking-wide font-bold"
        data-translate-key="projects">
        Mis Proyectos
      </p>
    </div>
    <section class="flex flex-col gap-8">
      {
        projects.map((project) => (
          <article>
            <Card>
              <CardProject
                image={project.image}
                alt={project.alt}
                href={project.href}
                title={project.title}
                descriptionKey={project.descriptionKey}
                description={translations.es[project.descriptionKey] ?? ""}
                badges={project.badges}
              />
            </Card>
          </article>
        ))
      }
    </section>
  </main>
</Card>
