---
export interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] md:text-sm font-medium text-green-500 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-900 hover:shadow-[0_0_8px_rgba(74,222,128,0.2),0_0_16px_rgba(74,222,128,0.1)] transition-all duration-300">
  {name}
</span>
